{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["gitlab>tnoff-projects/github-workflows//renovate/default"],
  "enabledManagers": ["gitlabci", "gitlabci-include", "dockerfile", "pip_requirements", "custom.regex"],
  "packageRules": [
    {
      "matchPackageNames": ["pytest", "pytest-cov", "pytest-mock", "requests-mock", "tox", "pylint", "bandit"],
      "additionalBranchPrefix": "test-",
      "automerge": true
    },
    {
      "matchPackageNames": ["awscli"],
      "additionalBranchPrefix": "dev-",
      "automerge": true
    },
    {
      "matchManagers": ["pip_requirements", "dockerfile"],
      "matchPackageNames": ["!pytest", "!pytest-cov", "!pytest-mock", "!requests-mock", "!tox", "!pylint", "!bandit", "!awscli"],
      "additionalBranchPrefix": "dev-"
    }
  ]
}
